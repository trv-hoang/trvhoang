{
  "name": "trhoag",
  "version": "1.0.0",
  "scripts": {
    "dev": "npx concurrently \"npm run dev:hugo\" \"npm run dev:tailwind\"",
    "dev:hugo": "hugo server -D -p 1315",
    "dev:tailwind": "npx @tailwindcss/cli -i ./assets/css/global.css -o ./static/global.css --watch",
    "build": "npx @tailwindcss/cli -i ./assets/css/global.css -o ./static/global.css --minify && hugo --gc --minify"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.0.0"
  }
}
